# =============================================================
#  SISVAC 2.0 — Copie para apps/web/.env.local e preencha
#  NUNCA commite o .env.local com valores reais
# =============================================================

# ── SUPABASE ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxx
SUPABASE_JWT_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── AUTH.JS — gere com: openssl rand -base64 32 ───────────────
AUTH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AUTH_URL=http://localhost:3000

# ── GOOGLE OAUTH (opcional) ───────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# ── NESTJS ────────────────────────────────────────────────────
API_INTERNAL_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
PORT=3001

# ── EMAIL (opcional por enquanto) ─────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=sisvac@seudominio.gov.br

# ── SEGURANÇA ─────────────────────────────────────────────────
NODE_ENV=development
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
CORS_ORIGINS=http://localhost:3000
